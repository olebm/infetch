# ── Supabase ─────────────────────────────────────────────────────────────────
# Supabase Cloud project — create at https://supabase.com
# Project URL + anon key are safe client-side (NEXT_PUBLIC_*).
# Service Role Key is server-only — never expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Postgres connection string — use the "Transaction" pooler URL from
# Supabase → Project Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres.YOURREF:PASSWORD@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Public app URL — required for Supabase magic-link redirects.
NEXT_PUBLIC_APP_URL=https://app.infetch.de

# ── Server ────────────────────────────────────────────────────────────────────
# In Docker/Coolify HOST is overridden to 0.0.0.0 automatically.
HOST=127.0.0.1
PORT=3000

# ── Secret Store ─────────────────────────────────────────────────────────────
# Used to encrypt IMAP/SMTP credentials stored in Postgres.
# macOS: falls back to OS Keychain automatically (no key needed in dev).
# Linux / Docker (Coolify): required — generate once, keep it safe.
# Generate: openssl rand -hex 32
SECRET_ENCRYPTION_KEY=

# ── Brevo (outbound email) ────────────────────────────────────────────────────
# Transactional email — onboarding, upgrade nudges, weekly digest.
# Create at: app.brevo.com → SMTP & API → API Keys
# Sender address must be verified in Brevo (domain or single address).
BREVO_API_KEY=
BREVO_FROM_EMAIL=noreply@infetch.de
BREVO_FROM_NAME=Infetch

# ── AI Proxy ─────────────────────────────────────────────────────────────────
# If set, AI calls are routed to the managed Infetch proxy (no user key needed).
# If unset, MISTRAL_API_KEY is used for in-process calls.
AI_PROXY_URL=
AI_PROXY_TOKEN=
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_WEBHOOK_SECRET=

# ── Stripe ────────────────────────────────────────────────────────────────────
# Secret Key (Developers → API Keys → Secret key)
STRIPE_SECRET_KEY=sk_live_...
# Webhook Signing Secret (Webhooks → dein Endpoint → Signing secret)
# Webhook URL: https://app.infetch.de/api/stripe/webhook
# Events: checkout.session.completed, customer.subscription.updated, customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_...
# Price IDs für Upgrade-CTAs (Products → Preis → Price ID)
STRIPE_PRICE_ID_PRO=price_...
STRIPE_PRICE_ID_BUSINESS=price_...
# Payment Links für Upgrade-Buttons im Frontend
STRIPE_PAYMENT_LINK_PRO=https://buy.stripe.com/...
STRIPE_PAYMENT_LINK_TEAM=https://buy.stripe.com/...

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_PORTALS=false
ENABLE_INBOUND_MAIL=false
ENABLE_API_INTEGRATIONS=false
AUTO_PILOT_ENABLED=true

# ── Brandfetch ────────────────────────────────────────────────────────────────
# Optional — improves vendor logo quality. Free at brandfetch.com
NEXT_PUBLIC_BRANDFETCH_TOKEN=

# ── Advanced / optional ───────────────────────────────────────────────────────
# SYNC_MONTHS_BACK=6
# AUTO_APPROVE_CONFIDENCE=0.90
# SELF_PROVISION_MIN_IMPORTS=3
# PORTAL_HEADLESS=true
# PORTAL_SCREENSHOT_ON_FAILURE=true

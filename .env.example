# ── Supabase ────────────────────────────────────────────────────────────────────
# Supabase Cloud project — create one at https://supabase.com
# Project URL + anon key are safe to expose client-side (NEXT_PUBLIC_*).
# Service Role Key is server-only — never expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL — used for magic-link redirects in dev test login.
# In production this is set automatically by Coolify/Hetzner.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Brandfetch Logo CDN — optional, improves vendor logo quality.
# Get your free client ID at https://brandfetch.com
NEXT_PUBLIC_BRANDFETCH_TOKEN=

# Local server
# When running via docker-compose, HOST is forced to 0.0.0.0 inside the container —
# docker-compose binds the port back to 127.0.0.1 on the host.
HOST=127.0.0.1
PORT=3000

SENTRY_DSN=https://4415ca4415e16669357ef6980bda859e@o4511382208970752.ingest.de.sentry.io/4511382408265808

# Database
DATABASE_URL=./data/invoice-agent.db

# ── Secret Store ────────────────────────────────────────────────────────────────
# On macOS: credentials are stored in the OS Keychain automatically (no key needed).
# On Linux / Docker (Hetzner, Coolify, etc.): set this key so credentials can be
# stored encrypted in SQLite instead. Generate once and keep it safe:
#   openssl rand -hex 32
# IMPORTANT: losing this key means losing access to all stored IMAP/SMTP credentials.
SECRET_ENCRYPTION_KEY=

# Storage
INVOICE_STORAGE_PATH=./data/invoices
RAW_TEXT_STORAGE_PATH=./data/raw-text
PORTAL_STORAGE_PATH=./data/sessions
AI_CACHE_STORAGE_PATH=./data/ai-cache
LOG_STORAGE_PATH=./data/logs

# AI
MISTRAL_API_KEY=
MISTRAL_ENABLED=true
MISTRAL_MODEL=
AI_EXTRACTION_MODE=mistral
AI_CACHE_ENABLED=true
AI_SEND_PDF_BINARY=false

# ── Resend (Email) ───────────────────────────────────────────────────────────────
# API key for outbound notifications (invoice digest, alerts).
# Get it at https://resend.com — free tier is sufficient for personal use.
RESEND_API_KEY=

# Inbound email — the domain you configure in Resend for receiving mail.
# Every user gets a unique address: {local_part}@{RESEND_INBOUND_DOMAIN}
RESEND_INBOUND_DOMAIN=in.infetch.de

# Shared secret for verifying Resend webhook signatures (HMAC-SHA256).
# Set the same value in Resend → Webhooks → Signing Secret.
# Generate: openssl rand -hex 32
RESEND_INBOUND_WEBHOOK_SECRET=

# ── Cron / Scheduled jobs ────────────────────────────────────────────────────────
# Bearer token that protects the /api/cron/* endpoints.
# Must match the Authorization header sent by your scheduler (Coolify cron, system cron, etc.).
# Generate: openssl rand -hex 32
CRON_SECRET=

# Mail and export are also configurable through the UI (stored in the secret store above).
MAIL_HOST=
MAIL_PORT=993
MAIL_SECURE=true
MAIL_USER=
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=

# Sync
SYNC_MONTHS_BACK=6
MAIL_FIRST_STRATEGY=true
PORTAL_FALLBACK_ENABLED=true

# Community recipes — override to point at a fork or private mirror.
# Default repository is invoice-agent/invoice-agent-recipes on GitHub.
# COMMUNITY_RECIPES_REPO=invoice-agent/invoice-agent-recipes
# COMMUNITY_RECIPES_BRANCH=main

# Logging
# LOG_LEVEL=info

# Portal agent — debug flags for real-world testing.
# Set PORTAL_HEADLESS=false to see the browser during portal runs.
# Set PORTAL_SLOWMO_MS=500 to slow each action down for observation.
# Failure screenshots land in $LOG_STORAGE_PATH/portal-failures/.
# PORTAL_HEADLESS=true
# PORTAL_SLOWMO_MS=0
# PORTAL_SCREENSHOT_ON_FAILURE=true
# PORTAL_VERBOSE=false

# Tier — free | pro | team. Defaults to free.
# Later this will be looked up via a Stripe webhook / license key,
# for now it's a manual override.
# INVOICE_AGENT_TIER=free

# Stripe Payment Links (https://dashboard.stripe.com/payment-links).
# When set, the UI shows an "Upgrade" button that opens the link in a new tab.
# STRIPE_PAYMENT_LINK_PRO=
# STRIPE_PAYMENT_LINK_TEAM=
